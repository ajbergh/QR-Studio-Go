{
  "name": "qr-studio",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Professional QR Code Generator - Desktop and Web Application",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "npm run typecheck && vite build",
    "build:web": "npm run build",
    "build:wails": "npm run typecheck && cross-env WAILS_BUILD=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "node --test ./tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "lucide-react": "^0.555.0",
    "qr-code-styling": "^1.9.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0"
  }
}
